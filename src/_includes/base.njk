<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | ENDD COMMAND CENTER</title>
    
    <!-- Path resolution using 11ty filters -->
    <link rel="stylesheet" href="{{ '/styles/main.css' | url }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Roboto+Condensed:wght@700&display=swap"
        rel="stylesheet">
    <link rel="icon" type="image/png" href="{{ '/assets/favicon.png' | url }}">
</head>

<body>
    <div class="hud-overlay"></div>
    <header>
        <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
            <a href="{{ '/' | url }}" class="logo" style="text-decoration: none;">
                <img src="{{ '/assets/header-logo.png' | url }}" class="logo-helmet pulse-active" alt="Knight Helmet">
                <span>ENDD COMMAND CENTER</span>
            </a>
            
            <div class="header-actions" style="display: flex; align-items: center; gap: 15px;">
                <nav class="language-switcher notranslate" style="color: #ffffff;">
                    <a href="javascript:void(0)" class="lang-link active" onclick="translatePage('en')" style="color: #ffffff; border: 1px solid rgba(255,255,255,0.3); padding: 4px 8px; border-radius: 4px;">EN</a>
                    <a href="javascript:void(0)" class="lang-link" onclick="translatePage('ko')" style="color: rgba(255,255,255,0.7);">KO</a>
                    <a href="javascript:void(0)" class="lang-link" onclick="translatePage('es')" style="color: rgba(255,255,255,0.7);">ES</a>
                    <a href="javascript:void(0)" class="lang-link" onclick="translatePage('pt')" style="color: rgba(255,255,255,0.7);">PT</a>
                    <a href="javascript:void(0)" class="lang-link" onclick="translatePage('de')" style="color: rgba(255,255,255,0.7);">DE</a>
                </nav>
                
                <div id="auth-hud-container" class="auth-hud-widget" style="display: none;"></div>
            </div>
        </div>
    </header>

    <div id="google_translate_element" style="display:none"></div>

    <script type="text/javascript">
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                autoDisplay: false
            }, 'google_translate_element');
        }

        function translatePage(langCode) {
            var select = document.querySelector('select.goog-te-combo');
            if (select) {
                select.value = langCode;
                select.dispatchEvent(new Event('change'));
            }
            // Update active state
            document.querySelectorAll('.lang-link').forEach(link => {
                link.classList.remove('active');
                if (link.innerText.toLowerCase() === langCode) link.classList.add('active');
            });
        }
    </script>
    <script>
        // Automatic Icon/Emoji Detection for Lists
        document.addEventListener('DOMContentLoaded', () => {
            const emojiRegex = /^([\uD800-\uDBFF][\uDC00-\uDFFF]|[\u2000-\u32FF]|[\u2600-\u27BF])/;
            document.querySelectorAll('.tutorial-content li').forEach(li => {
                const text = li.textContent.trim();
                if (emojiRegex.test(text)) {
                    li.classList.add('has-icon');
                }
            });

            // Automatic Table Wrapping for Mobile
            document.querySelectorAll('.tutorial-content table').forEach(table => {
                const wrapper = document.createElement('div');
                wrapper.className = 'table-container';
                table.parentNode.insertBefore(wrapper, table);
                wrapper.appendChild(table);
            });
        });

        function copyIntel(id) {
            const url = id ? (window.location.href.split('#')[0] + '#' + id) : window.location.href.split('#')[0];
            navigator.clipboard.writeText(url);
            const selector = id ? `[onclick="copyIntel('${id}')"]` : '.share-guide-btn';
            document.querySelectorAll(selector).forEach(btn => {
                btn.classList.add('is-copied');
                setTimeout(() => btn.classList.remove('is-copied'), 2000);
            });
        }
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const authContainer = document.getElementById('auth-hud-container');
            if (!authContainer) return;
            
            try {
                const response = await fetch('/api/auth/session');
                const data = await response.json();
                
                if (data.authenticated && data.user) {
                    const user = data.user;
                    const roles = data.roles || [];
                    const LEADERSHIP_ROLE_ID = "1075074106980061184";
                    const isLeadership = roles.includes(LEADERSHIP_ROLE_ID);
                    
                    let avatarUrl;
                    if (user.avatar) {
                        avatarUrl = `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png`;
                    } else {
                        const defaultIdx = Number(BigInt(user.id) >> 22n) % 6;
                        avatarUrl = `https://cdn.discordapp.com/embed/avatars/${defaultIdx}.png`;
                    }
                    
                    const roleBadge = isLeadership 
                        ? '<span class="hud-role-badge leadership">🛡️ R4 / LEADERSHIP</span>' 
                        : '<span class="hud-role-badge member">⚔️ ALLIANCE MEMBER</span>';
                        
                    const displayName = user.globalName || user.username;
                    
                    authContainer.innerHTML = `
                        <div class="user-dropdown-container">
                            <button class="avatar-trigger" id="avatar-trigger-btn" aria-haspopup="true" aria-expanded="false" aria-label="Toggle user menu">
                                <img src="${avatarUrl}" class="profile-avatar-only" alt="${user.username}'s Avatar">
                            </button>
                            
                            <div class="hud-dropdown-menu" id="hud-dropdown-menu">
                                <div class="dropdown-header">
                                    <span class="dropdown-username">${displayName}</span>
                                    ${roleBadge}
                                </div>
                                <div class="dropdown-divider"></div>
                                <a href="/api/auth/logout" class="dropdown-item logout-item">
                                    <span class="item-icon">🚪</span>
                                    <span>Log Out</span>
                                </a>
                            </div>
                        </div>
                    `;

                    // Toggle functionality
                    const trigger = document.getElementById('avatar-trigger-btn');
                    const menu = document.getElementById('hud-dropdown-menu');
                    
                    if (trigger && menu) {
                        trigger.addEventListener('click', (e) => {
                            e.stopPropagation();
                            const isActive = menu.classList.contains('active');
                            if (isActive) {
                                menu.classList.remove('active');
                                trigger.setAttribute('aria-expanded', 'false');
                            } else {
                                menu.classList.add('active');
                                trigger.setAttribute('aria-expanded', 'true');
                            }
                        });
                        
                        // Close menu when clicking outside
                        document.addEventListener('click', (e) => {
                            if (!menu.contains(e.target) && !trigger.contains(e.target)) {
                                menu.classList.remove('active');
                                trigger.setAttribute('aria-expanded', 'false');
                            }
                        });
                    }
                } else {
                    authContainer.innerHTML = `
                        <a href="/login/" class="hud-btn login-btn">🔒 AUTHENTICATE</a>
                    `;
                }
            } catch (err) {
                console.error('Error fetching auth session:', err);
                authContainer.innerHTML = `
                    <a href="/login/" class="hud-btn login-btn">🔒 AUTHENTICATE</a>
                `;
            }
        });
    </script>
    <script type="text/javascript"
        src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <main class="container">
        {% if tags and "tutorial" in tags %}
        <div class="share-guide-bar">
            <div class="share-guide-label">🔗 SHARE THIS TACTICAL GUIDE</div>
            <button class="share-intel share-guide-btn" onclick="copyIntel('')"></button>
        </div>
        {% endif %}
        {{ content | safe }}
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2026 ENDD Alliance | VERSION: {{ version }}</p>
        </div>
    </footer>
</body>

</html>
