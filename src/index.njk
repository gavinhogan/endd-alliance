---
layout: base.njk
---
<section class="hero" style="text-align: center; padding: 40px 0;">
    <div class="hero-logo" style="margin-bottom: 25px;">
        <img src="{{ '/assets/hero-logo.png' | url }}" alt="ENDD Alliance Logo" class="pulse-active" style="width: 140px; height: 140px; border-radius: 24px; box-shadow: var(--card-shadow); border: 3px solid var(--accent-primary);">
    </div>
    <h1>STRATEGIC REPOSITORY</h1>
    <p class="status-badge" style="display: inline-block; background: rgba(0, 157, 255, 0.1); color: var(--accent-primary); font-family: var(--font-heading); font-size: 0.8rem; font-weight: 800; padding: 4px 12px; border-radius: 20px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px;">🛡️ STATE 2143 ACTIVE 🛡️</p>
    <p style="max-width: 600px; margin: 0 auto; line-height: 1.6; font-weight: 500;">
        Official tactical guides and operational procedures from <strong style="color: var(--text-on-light);">ConfuzedCorp</strong> for the <strong style="color: var(--text-on-light);">Knights of the End</strong> on <strong style="color: var(--text-on-light);">2143</strong>.
    </p>
</section>

<!-- SEASON 1 OPERATIONS DECK -->
<div class="season-section-title">
    <span>❄️ SEASON 1: THE CRIMSON PLAGUE</span>
    <span style="font-size: 0.65rem; background: var(--season-primary); color: #ffffff; padding: 2px 8px; border-radius: 20px; font-weight: 800; letter-spacing: 0.5px;">☣️ ACTIVE CAMPAIGN</span>
</div>

<nav class="card-grid" style="margin-bottom: 40px;">
    {% if collections.season1 and collections.season1.length > 0 %}
        {% for guide in collections.season1 %}
        <a href="{{ guide.url | url }}" class="card season-card">
            <h3>{{ guide.data.emoji }} {{ guide.data.title }}</h3>
            <p>{{ guide.data.description }}</p>
            <span class="season-badge">🧬 PLAGUE TACTIC</span>
        </a>
        {% endfor %}
    {% else %}
        <div style="background: rgba(255, 56, 96, 0.02); border: 1px dashed rgba(255, 56, 96, 0.25); border-radius: 12px; padding: 30px; text-align: center; width: 100%; color: var(--text-secondary); font-family: var(--font-heading); font-weight: 700; font-size: 0.95rem;">
            📅 NO ACTIVE SEASON 1 OPERATIONS YET — LOGISTICS ARE CURRENTLY COMPILING
        </div>
    {% endif %}
</nav>

<!-- CORE REPOSITORY DIRECTIVES DECK -->
<div class="section-title">
    <span>🛡️ CORE MANIFOLD DIRECTIVES</span>
    <span style="font-size: 0.65rem; background: var(--accent-primary); color: #ffffff; padding: 2px 8px; border-radius: 20px; font-weight: 800; letter-spacing: 0.5px;">📚 STANDARD GUIDES</span>
</div>

<nav class="card-grid">
    {% for tutorial in collections.tutorial %}
    <a href="{{ tutorial.url | url }}" class="card">
        <h3>{{ tutorial.data.emoji }} {{ tutorial.data.title }}</h3>
        <p>{{ tutorial.data.description }}</p>
    </a>
    {% endfor %}
</nav>
